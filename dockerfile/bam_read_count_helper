FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV CONDA_DIR=/opt/conda
ENV PATH=$CONDA_DIR/bin:$PATH

# --- 1. Install system dependencies ---
RUN apt-get update && apt-get install -y \
    wget \
    bzip2 \
    ca-certificates \
    git \
    gcc \
    make \
    curl \
    zlib1g-dev \
    libbz2-dev \
    liblzma-dev \
    libcurl4-openssl-dev \
    libssl-dev \
    libncurses5 \
    libncursesw5 \
    libz-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# --- 2. Install Miniconda ---
RUN wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O miniconda.sh && \
    bash miniconda.sh -b -p $CONDA_DIR && \
    rm miniconda.sh

# Add Conda to PATH
ENV PATH=$CONDA_DIR/bin:$PATH

# --- 3. Configure Conda and install packages ---
RUN conda init && \
    conda config --add channels bioconda && \
    conda config --add channels conda-forge && \
    conda config --set channel_priority strict && \
    conda config --set auto_activate_base false && \
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main && \
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r && \
    conda create -y -n bamenv \
        python=3.10 \
        bam-readcount \
        cyvcf2 \
        samtools \
        pip && \
    conda clean -afy

# --- 4. Set env PATH to use conda environment ---
ENV PATH /opt/conda/envs/bamenv/bin:$PATH

# --- 5. Make bam-readcount available globally ---
RUN ln -s /opt/conda/envs/bamenv/bin/bam-readcount /usr/local/bin/bam-readcount

# --- 6. Copy your Python helper script ---
COPY bam_readcount_helper.py /opt/bam_readcount_helper.py

# --- 7. Set working directory and entrypoint ---
WORKDIR /data
ENTRYPOINT ["bash"]
